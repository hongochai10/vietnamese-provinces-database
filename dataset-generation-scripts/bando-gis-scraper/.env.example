# Bando GIS Scraper Configuration
# Copy this file to .env and update with your values

# Website URL to scrape
BANDO_WEBSITE_URL=https://sapnhap.bando.com.vn/

# Headless mode configuration
# Set to 'true' for headless mode (no browser UI), 'false' for non-headless mode (with browser UI)
# Default: false (shows browser UI)
HEADLESS=false

# Parallel scraping mode configuration
# Enable parallel scraping to dramatically improve performance by processing multiple provinces simultaneously
# Set to 'true' to enable parallel mode, 'false' to use sequential mode (default behavior)
# Default: false (sequential mode)
PARALLEL=false

# Number of concurrent workers for parallel scraping
# Controls how many provinces are scraped simultaneously in parallel mode
# Recommended values:
#   - 2-4: For systems with limited resources (2-4GB RAM, 2-4 CPU cores)
#   - 4-6: For systems with moderate resources (4-8GB RAM, 4-8 CPU cores)
#   - 6-8: For systems with good resources (8-16GB RAM, 8+ CPU cores)
# Default: 4
# Note: Setting this too high may cause browser crashes due to memory/CPU constraints
WORKER_COUNT=4

# Maximum retry attempts for failed provinces in parallel mode
# If a province fails to scrape, it will be retried up to this many times
# Default: 2
MAX_RETRIES=2

# Target province index for scraping (optional)
# If not set or commented out, the scraper will scrape all provinces
# If set, only the specified province will be scraped
# Uses one-based indexing (1 = first province, 2 = second province, etc.)
# The valid range is dynamic and depends on the actual number of provinces on the website
# Typical range: 1 to 34 (as shown on the website)
# Example: TARGET_PROVINCE_INDEX=1 to scrape the first province
# Example: TARGET_PROVINCE_INDEX=2 to scrape the second province
# Note: Set to a value outside the valid range to trigger an error and see the actual province count
# TARGET_PROVINCE_INDEX=1